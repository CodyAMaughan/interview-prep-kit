{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/git-safety.sh\"" },
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/secret-scan.sh\"" }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/secret-scan.sh\"" }
        ]
      }
    ],
    "Stop": [
      { "hooks": [{ "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/test-gate.sh\"" }] }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/capture-learnings.sh\"" }] }
    ],
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/.agent/hooks/load-memory.sh\"" }] }
    ]
  }
}
